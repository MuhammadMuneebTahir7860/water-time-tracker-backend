# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/water-time-tracker

# Secret for signing JWTs (use a long random string in production)
JWT_SECRET=your-secret-key-here

# Frontend URL for CORS (no trailing slash)
FRONTEND_URL=https://water-time-tracker-frontend.vercel.app

# Local dev only (Vercel sets PORT automatically)
PORT=5000
